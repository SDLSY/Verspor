<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="26dp" />
            <gradient
                android:angle="315"
                android:endColor="#E8FAFD"
                android:startColor="#FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#BEE0E8" />
        </shape>
    </item>

    <item
        android:bottom="210dp"
        android:left="-50dp"
        android:right="120dp"
        android:top="-20dp">
        <shape android:shape="oval">
            <solid android:color="#50C8EEF6" />
        </shape>
    </item>

    <item
        android:bottom="-10dp"
        android:left="100dp"
        android:right="-10dp"
        android:top="220dp">
        <shape android:shape="oval">
            <solid android:color="#38A9E5C9" />
        </shape>
    </item>
</layer-list>
