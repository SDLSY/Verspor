<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.NewStart.Card.Inline"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_metric_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.NewStart.CardTitle"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_metric_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_outline"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textAppearance="@style/TextAppearance.NewStart.StatusPill" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_metric_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.NewStart.CardValue"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tv_metric_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.NewStart.CardNote" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_metric_value"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:minHeight="6dp"
            app:trackColor="@color/card_stroke" />

        <TextView
            android:id="@+id/tv_metric_helper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.NewStart.CardNote"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
