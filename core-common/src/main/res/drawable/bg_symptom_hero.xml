<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="30dp" />
            <gradient
                android:angle="315"
                android:endColor="#DDF7FB"
                android:startColor="#F9FEFF" />
        </shape>
    </item>

    <item
        android:bottom="210dp"
        android:left="-40dp"
        android:right="120dp"
        android:top="-30dp">
        <shape android:shape="oval">
            <solid android:color="#55B6E8F5" />
        </shape>
    </item>

    <item
        android:bottom="-20dp"
        android:left="120dp"
        android:right="-20dp"
        android:top="210dp">
        <shape android:shape="oval">
            <solid android:color="#35A4E0CA" />
        </shape>
    </item>
</layer-list>
