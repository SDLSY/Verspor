<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.NewStart" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>

        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_card_subtle</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/card_stroke</item>

        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="materialCardViewStyle">@style/Widget.NewStart.Card</item>
        <item name="bottomNavigationStyle">@style/Widget.NewStart.BottomNavigation</item>
        <item name="chipStyle">@style/Widget.NewStart.Chip.Filter</item>
        <item name="materialButtonStyle">@style/Widget.NewStart.Button.Primary</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.NewStart.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.NewStart.HeadlineMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.NewStart.TitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.NewStart.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.NewStart.BodyMedium</item>
    </style>

    <style name="Theme.NewStart" parent="Base.Theme.NewStart" />

    <style name="TextAppearance.NewStart.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.NewStart.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.NewStart.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.NewStart.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.NewStart.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.NewStart.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/card_corner_standard</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.NewStart.Card.Subtle" parent="Widget.NewStart.Card">
        <item name="cardBackgroundColor">@color/surface_card_subtle</item>
    </style>

    <style name="Widget.NewStart.HeroCard" parent="Widget.NewStart.Card">
        <item name="cardCornerRadius">@dimen/hero_corner</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="Widget.NewStart.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/bg_bottom_nav</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemRippleColor">@color/nav_active_indicator</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.NewStart.BottomNavigation.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.NewStart.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/nav_active_indicator</item>
        <item name="shapeAppearance">@style/ShapeAppearance.NewStart.ActiveIndicator</item>
    </style>

    <style name="ShapeAppearance.NewStart.ActiveIndicator" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">14dp</item>
    </style>

    <style name="Widget.NewStart.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_height_primary</item>
    </style>

    <style name="Widget.NewStart.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/button_height_secondary</item>
    </style>

    <style name="Widget.NewStart.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="android:minHeight">@dimen/button_height_secondary</item>
    </style>

    <style name="Widget.NewStart.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="Widget.NewStart.Button.SurfaceToggle" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/md_theme_light_outlineVariant</item>
    </style>

    <style name="Widget.NewStart.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">14dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
