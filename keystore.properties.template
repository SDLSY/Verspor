# Keystore 配置文件
# 重要：不要将此文件提交到版本控制系统！

# Keystore 文件路径（相对于项目根目录）
storeFile=changgenghuan-release.jks

# Keystore 密码
storePassword=你的Keystore密码

# Key 别名
keyAlias=changgenghuan-key

# Key 密码
keyPassword=你的Key密码

# 使用说明：
# 1. 在 Android Studio 中创建 keystore 文件后
# 2. 将上述信息替换为您的实际密码
# 3. 确保 changgenghuan-release.jks 文件在项目根目录
# 4. 此文件已添加到 .gitignore，不会被提交到 Git
