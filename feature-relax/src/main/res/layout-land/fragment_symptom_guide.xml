<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    tools:context=".ui.relax.SymptomGuideFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="18dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_symptom_back_to_home"
            style="@style/Widget.NewStart.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="@string/relax_back_to_today" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/symptom_guide_title"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/symptom_guide_page_title"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/symptom_guide_page_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_symptom_open_relax_center"
            style="@style/Widget.NewStart.Button.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/symptom_open_recovery_center"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.NewStart.HeroCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.15">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_symptom_hero"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_body_title"
                                android:textColor="@color/text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/symptom_body_subtitle"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_surface_front"
                                style="@style/Widget.NewStart.Button.SurfaceToggle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="0dp"
                                android:text="@string/symptom_surface_front" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_surface_back"
                                style="@style/Widget.NewStart.Button.SurfaceToggle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:minWidth="0dp"
                                android:text="@string/symptom_surface_back" />
                        </LinearLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="520dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_symptom_stage">

                        <ImageView
                            android:id="@+id/img_body_map"
                            android:layout_width="420dp"
                            android:layout_height="420dp"
                            android:layout_gravity="center"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/symptom_guide_front" />

                        <TextView
                            android:id="@+id/btn_marker_head"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_gravity="top|center_horizontal"
                            android:layout_marginTop="62dp"
                            android:background="@drawable/bg_symptom_hotspot"
                            android:gravity="center"
                            android:text="头"
                            android:textColor="@color/md_theme_light_onPrimaryContainer"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_marker_chest"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="196dp"
                            android:background="@drawable/bg_symptom_hotspot"
                            android:gravity="center"
                            android:text="胸"
                            android:textColor="@color/md_theme_light_onPrimaryContainer"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_marker_abdomen"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="302dp"
                            android:background="@drawable/bg_symptom_hotspot"
                            android:gravity="center"
                            android:text="腹"
                            android:textColor="@color/md_theme_light_onPrimaryContainer"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_marker_limb"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="68dp"
                            android:background="@drawable/bg_symptom_hotspot"
                            android:gravity="center"
                            android:text="肢"
                            android:textColor="@color/md_theme_light_onPrimaryContainer"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_body_map_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/symptom_body_hint_front"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/symptom_selected_markers_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_selected_markers_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/symptom_selected_markers_empty"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_selected_markers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleLine="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="0.85"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.NewStart.Card.Subtle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/symptom_red_flag_title"
                            android:textColor="@color/status_negative"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/symptom_red_flag_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.ChipGroup
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:singleLine="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_chest_pain"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_red_flag_chest_pain" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_breath"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_red_flag_breath" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_consciousness"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_red_flag_consciousness" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_high_fever"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_red_flag_fever" />
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.NewStart.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/symptom_quick_title"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/symptom_quick_subtitle"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.ChipGroup
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:singleLine="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_headache"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_headache" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_chest_tightness"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_chest_tightness" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_short_breath"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_temple_pain" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_abdominal_pain"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_abdominal_pain" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_dizziness"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_wrist_pain" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_muscle_soreness"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_knee_pain" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_fatigue"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_sweating" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_quick_fever"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_quick_fever"
                                android:visibility="gone" />
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.NewStart.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/symptom_supplement_title"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/symptom_trigger_title"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_triggers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_trigger_stress"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_trigger_stress" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_trigger_exercise"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_trigger_exercise" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_trigger_food"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_trigger_food" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_trigger_night"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_trigger_night" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_trigger_unknown"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/symptom_trigger_unknown" />
                        </com.google.android.material.chip.ChipGroup>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/symptom_assoc_title"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.chip.ChipGroup
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:singleLine="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_assoc_fatigue"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/symptom_assoc_fatigue" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_assoc_dizziness"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/symptom_assoc_dizziness" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_assoc_nausea"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/symptom_assoc_nausea" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_assoc_cough"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/symptom_assoc_cough" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_assoc_insomnia"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/symptom_assoc_insomnia" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_assoc_fever"
                                style="@style/Widget.NewStart.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/symptom_assoc_fever" />
                        </com.google.android.material.chip.ChipGroup>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/symptom_note_title"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_symptom_additional_note"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/symptom_note_hint"
                                android:maxLines="4"
                                android:minLines="3"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="@string/symptom_device_title"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_device_evidence"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/symptom_device_evidence_missing"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_generate_outcome"
                            style="@style/Widget.NewStart.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:enabled="false"
                            android:text="@string/symptom_generate_action" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_outcome"
            style="@style/Widget.NewStart.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/symptom_outcome_title"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_outcome_risk_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/badge_background"
                        android:paddingStart="12dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="5dp"
                        android:text="@string/symptom_risk_medium"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_outcome_risk_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/symptom_suspected_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_suspected_1_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_suspected_1_reason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
